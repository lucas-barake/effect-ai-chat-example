{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "22.14.0",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "check": "dprint fmt && oxlint --fix --tsconfig tsconfig.json --type-aware --quiet && oxlint --tsconfig tsconfig.json --type-aware --quiet && tsc -b",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "test": "vitest run",
    "migrate": "pnpm --filter @app/server migrate",
    "dev:server": "pnpm --filter @app/server dev",
    "dev:client": "pnpm --filter @app/client dev"
  },
  "devDependencies": {
    "@app/scripts": "workspace:*",
    "@effect/vitest": "4.0.0-beta.88",
    "@types/node": "^22.8.5",
    "dprint": "^0.48.0",
    "oxlint": "^1.23.0",
    "oxlint-tsgolint": "^0.15.0",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "overrides": {
      "effect": "4.0.0-beta.88",
      "@effect/platform-browser": "4.0.0-beta.88",
      "@effect/platform-bun": "4.0.0-beta.88",
      "@effect/platform-node": "4.0.0-beta.88",
      "@effect/sql-pg": "4.0.0-beta.88",
      "@effect/vitest": "4.0.0-beta.88",
      "@effect/atom-react": "4.0.0-beta.88",
      "@effect/ai-openai-compat": "4.0.0-beta.88",
      "@effect/opentelemetry": "4.0.0-beta.88",
      "@opentelemetry/sdk-trace-base": "2.8.0",
      "@opentelemetry/sdk-trace-node": "2.8.0",
      "@opentelemetry/semantic-conventions": "1.41.1",
      "@opentelemetry/exporter-trace-otlp-http": "0.219.0"
    },
    "onlyBuiltDependencies": [
      "dprint"
    ]
  }
}
